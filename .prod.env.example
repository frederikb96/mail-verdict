# MailVerdict Production Environment
# Copy to .prod.env and fill in values
# Usage: podman compose --env-file .prod.env up -d

# OpenAI API key for AI verdict and embeddings
OPENAI_API_KEY=

# Fernet encryption key for IMAP/SMTP credentials
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MAIL_VERDICT_ENCRYPTION_KEY=

# Database password (use a strong password for production)
POSTGRES_PASSWORD=

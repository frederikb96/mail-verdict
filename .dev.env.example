# MailVerdict Development Environment
# Copy to .dev.env and fill in values
# Usage: podman compose --env-file .dev.env -f compose.dev.yaml up -d

# OpenAI API key for AI verdict and embeddings
OPENAI_API_KEY=

# AES-256-GCM encryption key for IMAP/SMTP credentials (shared with PostIMAP)
# Generate: python -c "import os; print(os.urandom(32).hex())"
# Must be 64 hex characters (32 bytes). Same key used by PostIMAP.
MAIL_VERDICT_ENCRYPTION_KEY=
ENCRYPTION_KEY=

# Database password (dev uses simple password, matches compose.dev.yaml)
POSTGRES_PASSWORD=devpass
